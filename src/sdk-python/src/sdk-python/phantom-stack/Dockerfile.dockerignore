# Build context excludes for the phantom-stack image.
# Keeps the image lean by dropping local caches/artifacts. Source, tests,
# pyproject.toml and README.md are all retained (needed for the editable install
# and the test suite).
**/__pycache__
**/*.pyc
.venv
.mypy_cache
.pytest_cache
.ruff_cache
build
dist
.coverage*
.audio_cache
**/.DS_Store
