# Build-context excludes for the phantom-stack image build.
# Keeps the context small; the package metadata only needs src/strands.
**/__pycache__
**/*.pyc
.git
.venv
build
dist
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
.coverage*
# Nested duplicate source tree (not part of the installable package)
src/sdk-python
phantom-stack
